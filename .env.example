# Supabase (service role — nunca commitar valor real)
SUPABASE_URL=https://seu-projeto.supabase.co
# service_role legada (eyJ...) OU secret key nova (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=sua_chave_aqui

# Meta Graph API (disparador apioficial — src/index.js)
META_GRAPH_API_VERSION=v25.0
PORT=3080
SEND_INTERVAL_MS=2000
POLL_IDLE_MS=2000
MAX_RETRIES=3

# Evolution API (disparador Individual + Grupos — src/workers/evolution.js)
EVOLUTION_BASE_URL=https://evolution2.victoreder.com.br
EVOLUTION_API_KEY=sua-apikey-global-evolution

# Inbound webhooks (src/inbound.js)
INBOUND_PORT=3090
EVENTS_META_PATH=/backend/webhook-eventsmeta
EVOLUTION_WEBHOOK_PATH=/backend/webhook-mensagens
AGENT_POLL_MS=500

# Agente IA (inbound)
OPENAI_API_KEY=sk-...
REDIS_URL=redis://redis:6379
CALCULAR_TOKEN_URL=https://webhook2.victoreder.com.br/webhook/calcular-token
AGENT_MAX_TOOL_ROUNDS=6

# Minio / S3 (mídias Meta no eventsmeta)
S3_ENDPOINT=https://s32.victoreder.com.br
S3_ACCESS_KEY_ID=sua_access_key
S3_SECRET_ACCESS_KEY=sua_secret_key
S3_BUCKET=n8n
S3_PUBLIC_BASE_URL=https://s32.victoreder.com.br/n8n
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
